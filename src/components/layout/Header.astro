---
import { NAV, SOCIAL, SITE } from '../../lib/constants';
---

<header class="site-header">
  <div class="container header-inner">
    <button class="menu-btn" type="button" aria-label="Open menu" id="menu-toggle">
      <span class="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </span>
      <b>Menu</b>
    </button>

    <a href="/" class="wordmark" aria-label="Brick Wire home">
      Brick <em>Wire</em><sup>&reg;</sup>
    </a>

    <div class="header-actions">
      <a href="/search/" class="search-icon" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
      </a>
      <a href="/newsletter-signup/" class="header-cta">SUBSCRIBE</a>
    </div>
  </div>

  <div class="mega-menu" id="mega-menu">
    <div class="container">
      <div class="mega-menu-grid">
        <nav class="mega-nav-primary">
          <div class="mega-nav-column">
            <h4 class="mega-nav-title">{NAV.briefs.label}</h4>
            <div class="mega-nav-subs">
              <div>
                <p class="mega-nav-subtitle">Markets</p>
                <ul class="mega-nav-links">
                  {NAV.briefs.markets.map(m => <li><a href={m.path}>{m.label}</a></li>)}
                </ul>
              </div>
              <div>
                <p class="mega-nav-subtitle">Sectors</p>
                <ul class="mega-nav-links">
                  {NAV.briefs.sectors.map(s => <li><a href={s.path}>{s.label}</a></li>)}
                </ul>
              </div>
            </div>
          </div>
          <div class="mega-nav-column">
            <h4 class="mega-nav-title">{NAV.newsletters.label}</h4>
            <ul class="mega-nav-links">
              {NAV.newsletters.editions.map(e => <li><a href={e.path}>{e.label}</a></li>)}
            </ul>
          </div>
          <div class="mega-nav-column">
            <h4 class="mega-nav-title">{NAV.reviews.label}</h4>
            <p class="mega-nav-desc">Compare reviews and prices on the best commercial real estate software and products.</p>
            <ul class="mega-nav-links">
              {NAV.reviews.featured.map(r => <li><a href={r.path}>{r.label}</a></li>)}
            </ul>
            <a href="/reviews/" class="mega-nav-viewall">View All Reviews</a>
          </div>
        </nav>
        <aside class="mega-nav-secondary">
          <div>
            {NAV.directLinks.map(l => (
              <a href={l.path} class="mega-nav-direct">{l.label}</a>
            ))}
          </div>
          <div>
            <p class="mega-nav-subtitle">Resources</p>
            <ul class="mega-nav-links">
              {NAV.resources.map(r => <li><a href={r.path}>{r.label}</a></li>)}
            </ul>
          </div>
          <div>
            <p class="mega-nav-subtitle">About Us</p>
            <ul class="mega-nav-links">
              {NAV.about.map(a => <li><a href={a.path} target={a.path.startsWith('http') ? '_blank' : undefined}>{a.label}</a></li>)}
            </ul>
          </div>
          <div class="mega-nav-social">
            <p class="mega-nav-subtitle">Follow us</p>
            <div class="social-row">
              {SOCIAL.map(s => (
                <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
                  {s.label === 'LinkedIn' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  )}
                  {s.label === 'X (Twitter)' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  )}
                  {s.label === 'Instagram' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  )}
                  {s.label === 'Facebook' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                  )}
                  {s.label === 'YouTube' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                  )}
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mega-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      document.body.classList.toggle('menu-open', isOpen);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) {
        menu.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('menu-open');
      }
    });
  }
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background: var(--color-bg-white);
    border-bottom: 1px solid var(--color-border);
    z-index: 100;
  }
  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 100%;
  }
  .menu-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 0;
    font-weight: 700;
    font-size: 14px;
    width: max-content;
    color: var(--color-text-primary);
  }
  .hamburger {
    position: relative;
    width: 27px;
    height: 2px;
  }
  .hamburger span {
    display: block;
    position: absolute;
    width: 27px;
    height: 2px;
    background: var(--color-text-primary);
    transition: all var(--transition-fast);
  }
  .hamburger span:first-child { transform: translateY(-8px); }
  .hamburger span:nth-child(2) { transform: translateY(0); }
  .hamburger span:nth-child(3) { transform: translateY(8px); }
  .wordmark {
    font-family: var(--font-heading);
    font-size: 2.1875rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    white-space: nowrap;
    text-decoration: none;
    justify-self: center;
  }
  .wordmark em {
    font-style: normal;
    color: var(--color-accent);
  }
  .wordmark sup {
    font-size: 0.625rem;
    font-weight: 600;
    vertical-align: super;
    color: var(--color-accent);
    margin-left: 2px;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 28px;
    justify-self: end;
  }
  .search-icon {
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    transition: color var(--transition-fast);
  }
  .search-icon:hover {
    color: var(--color-accent);
  }
  .header-cta {
    padding: 12px 28px;
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: background 0.15s ease;
    display: inline-flex;
    align-items: center;
  }
  .header-cta:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  .mega-menu {
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-bg-white);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all var(--transition-base);
    overflow-y: auto;
    z-index: 99;
  }
  .mega-menu.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .mega-menu-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    padding: 2rem 0 4rem;
  }
  .mega-nav-primary {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .mega-nav-secondary {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-left: 2rem;
    border-left: 1px solid var(--color-border);
  }
  .mega-nav-title {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .mega-nav-subtitle {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .mega-nav-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .mega-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .mega-nav-links a {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-body);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .mega-nav-links a:hover {
    color: var(--color-accent);
  }
  .mega-nav-subs {
    display: flex;
    gap: 2rem;
  }
  .mega-nav-viewall {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .mega-nav-direct {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    padding: 0.5rem 0;
    transition: color var(--transition-fast);
  }
  .mega-nav-direct:hover {
    color: var(--color-accent);
  }
  .mega-nav-social {
    margin-top: auto;
  }
  .social-row {
    display: flex;
    gap: 12px;
  }
  .social-row a {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }
  .social-row a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 62em) {
    .mega-menu-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .mega-nav-primary {
      grid-template-columns: 1fr 1fr;
    }
    .mega-nav-secondary {
      border-left: none;
      padding-left: 0;
    }
    .mega-nav-subs {
      flex-direction: column;
      gap: 1rem;
    }
  }
  @media (max-width: 48em) {
    .mega-nav-primary {
      grid-template-columns: 1fr;
    }
    .menu-btn b {
      display: none;
    }
    .header-cta {
      display: none;
    }
    .wordmark {
      font-size: 1.5rem;
    }
  }
</style>

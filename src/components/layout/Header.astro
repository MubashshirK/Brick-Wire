---
import { NAV, SOCIAL, SITE } from '../../lib/constants';

const currentPath = Astro.url.pathname;

function isActive(path: string): boolean {
  if (path === currentPath) return true;
  if (path !== '/' && currentPath.startsWith(path)) return true;
  return false;
}
function isSectionActive(items: { path: string }[]): boolean {
  return items.some(i => isActive(i.path));
}
---

<header class="site-header">
  <div class="container header-inner">
    <button class="menu-btn" type="button" aria-label="Open menu" id="menu-toggle" aria-expanded="false">
      <span class="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </span>
      <b>Menu</b>
    </button>

    <a href="/" class="wordmark" aria-label="Brick Wire home">
      <img src={SITE.logo} alt="Brick Wire" class="wordmark-img" />
      <span class="wordmark-text">Brick <em>Wire</em></span>
    </a>

    <div class="header-actions">
      <a href="/search/" class="search-icon" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
        </svg>
      </a>
      <a href="/newsletter-signup/" class="header-cta">SUBSCRIBE</a>
    </div>
  </div>

  <div class="mega-menu" id="mega-menu" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <div class="mega-menu-top">
      <button class="mega-menu-close-btn" id="mega-menu-close" aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="mega-menu-body">
      <div class="container">
        <div class="mega-direct-strip">
          {NAV.directLinks.map(l => (
            <a href={l.path} class:list={['mega-direct-pill', { 'mega-direct-pill--active': isActive(l.path) }]}>{l.label}</a>
          ))}
        </div>

        <div class="mega-menu-grid">
          <nav class="mega-nav-primary">
            <div class="mega-nav-accordion" class:list={{ 'is-expanded': isSectionActive([...NAV.briefs.markets, ...NAV.briefs.sectors]) }}>
              <button class="mega-nav-accordion-trigger" data-accordion="briefs" aria-expanded="false">
                <span class="mega-nav-trigger-label">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
                  </svg>
                  {NAV.briefs.label}
                </span>
                <svg class="accordion-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="mega-nav-accordion-panel">
                <div class="mega-nav-subsection">
                  <p class="mega-nav-subtitle">Markets</p>
                  <ul class="mega-nav-links">
                    {NAV.briefs.markets.map(m => (
                      <li><a href={m.path} class:list={{ 'nav-link-active': isActive(m.path) }}>{m.label}</a></li>
                    ))}
                  </ul>
                </div>
                <div class="mega-nav-subsection">
                  <p class="mega-nav-subtitle">Sectors</p>
                  <ul class="mega-nav-links">
                    {NAV.briefs.sectors.map(s => (
                      <li><a href={s.path} class:list={{ 'nav-link-active': isActive(s.path) }}>{s.label}</a></li>
                    ))}
                  </ul>
                </div>
                <a href="/briefs/" class="mega-nav-viewall">View All Briefs <span class="nav-arrow">&rarr;</span></a>
              </div>
            </div>

            <div class="mega-nav-accordion" class:list={{ 'is-expanded': isSectionActive(NAV.newsletters.editions) }}>
              <button class="mega-nav-accordion-trigger" data-accordion="newsletters" aria-expanded="false">
                <span class="mega-nav-trigger-label">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                  {NAV.newsletters.label}
                </span>
                <svg class="accordion-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="mega-nav-accordion-panel">
                <ul class="mega-nav-links">
                  {NAV.newsletters.editions.map(e => (
                    <li><a href={e.path} class:list={{ 'nav-link-active': isActive(e.path) }}>{e.label}</a></li>
                  ))}
                </ul>
                <a href="/newsletters/" class="mega-nav-viewall">View All Newsletters <span class="nav-arrow">&rarr;</span></a>
              </div>
            </div>

            <div class="mega-nav-accordion" class:list={{ 'is-expanded': isSectionActive(NAV.reviews.featured) }}>
              <button class="mega-nav-accordion-trigger" data-accordion="reviews" aria-expanded="false">
                <span class="mega-nav-trigger-label">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  {NAV.reviews.label}
                </span>
                <svg class="accordion-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="mega-nav-accordion-panel">
                <p class="mega-nav-section-desc">In-depth reviews of the leading CRE software and services.</p>
                <ul class="mega-nav-links">
                  {NAV.reviews.featured.map(r => (
                    <li><a href={r.path} class:list={{ 'nav-link-active': isActive(r.path) }}>{r.label}</a></li>
                  ))}
                </ul>
                <a href="/reviews/" class="mega-nav-viewall">View All Reviews <span class="nav-arrow">&rarr;</span></a>
              </div>
            </div>
          </nav>

          <aside class="mega-nav-secondary">
            <div class="mega-nav-secondary-section">
              <p class="mega-nav-subtitle">Resources</p>
              <ul class="mega-nav-links">
                {NAV.resources.map(r => (
                  <li><a href={r.path} class:list={{ 'nav-link-active': isActive(r.path) }}>{r.label}</a></li>
                ))}
              </ul>
            </div>

            <div class="mega-nav-secondary-section">
              <p class="mega-nav-subtitle">Company</p>
              <ul class="mega-nav-links">
                {NAV.about.map(a => (
                  <li>
                    <a
                      href={a.path}
                      target={a.path.startsWith('http') ? '_blank' : undefined}
                      rel={a.path.startsWith('http') ? 'noopener noreferrer' : undefined}
                      class:list={{ 'nav-link-active': !a.path.startsWith('http') && isActive(a.path) }}
                    >{a.label}</a>
                  </li>
                ))}
              </ul>
            </div>

            <div class="mega-nav-secondary-section mega-nav-social-section">
              <p class="mega-nav-subtitle">Follow us</p>
              <div class="social-row">
                {SOCIAL.map(s => (
                  <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="social-icon-link">
                    {s.label === 'LinkedIn' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    )}
                    {s.label === 'X (Twitter)' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    )}
                    {s.label === 'Instagram' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    )}
                    {s.label === 'Facebook' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    )}
                    {s.label === 'YouTube' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    )}
                  </a>
                ))}
              </div>
            </div>

            <a href="/newsletter-signup/" class="mega-drawer-cta btn btn-primary">Subscribe to Newsletter</a>
          </aside>
        </div>

        <div class="mega-menu-footer">
          <p class="mega-menu-footer-text">{SITE.copyright}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mega-menu-backdrop" id="mega-menu-backdrop"></div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mega-menu');
  const backdrop = document.getElementById('mega-menu-backdrop');
  const closeBtn = document.getElementById('mega-menu-close');
  const accordionTriggers = document.querySelectorAll('.mega-nav-accordion-trigger');

  function isDesktop() {
    return window.matchMedia('(min-width: 62em)').matches;
  }

  function openMenu() {
    menu.classList.add('is-open');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.classList.add('menu-open');
    if (!isDesktop()) {
      backdrop.classList.add('is-visible');
    }
  }

  function closeMenu() {
    menu.classList.remove('is-open');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('menu-open');
    backdrop.classList.remove('is-visible');
  }

  function toggleMenu() {
    if (menu.classList.contains('is-open')) {
      closeMenu();
    } else {
      openMenu();
    }
  }

  if (toggle) {
    toggle.addEventListener('click', toggleMenu);
  }

  if (closeBtn) {
    closeBtn.addEventListener('click', closeMenu);
  }

  if (backdrop) {
    backdrop.addEventListener('click', closeMenu);
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu.classList.contains('is-open')) {
      closeMenu();
    }
  });

  accordionTriggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      if (isDesktop()) {
        const panel = trigger.nextElementSibling;
        if (panel) {
          const isNowOpen = panel.style.display !== 'block';
          panel.style.display = isNowOpen ? 'block' : 'none';
          trigger.setAttribute('aria-expanded', String(isNowOpen));
        }
        return;
      }
      const accordion = trigger.closest('.mega-nav-accordion');
      if (accordion) {
        const isExpanded = accordion.classList.toggle('is-expanded');
        trigger.setAttribute('aria-expanded', String(isExpanded));
      }
    });
  });

  window.matchMedia('(min-width: 62em)').addEventListener('change', (e) => {
    if (e.matches && menu.classList.contains('is-open')) {
      backdrop.classList.remove('is-visible');
      accordionTriggers.forEach(trigger => {
        const accordion = trigger.closest('.mega-nav-accordion');
        if (accordion) accordion.classList.remove('is-expanded');
      });
    }
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background: var(--color-bg-white);
    border-bottom: 1px solid var(--color-border);
    z-index: 100;
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 100%;
  }

  .menu-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 0;
    font-weight: 700;
    font-size: 14px;
    width: max-content;
    color: var(--color-text-primary);
    transition: color var(--transition-fast);
  }
  .menu-btn:hover { color: var(--color-accent); }

  .hamburger {
    position: relative;
    width: 27px;
    height: 18px;
  }
  .hamburger span {
    display: block;
    position: absolute;
    left: 0;
    width: 27px;
    height: 2px;
    background: var(--color-text-primary);
    border-radius: 2px;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .menu-btn:hover .hamburger span { background: var(--color-accent); }
  .hamburger span:nth-child(1) { top: 0; }
  .hamburger span:nth-child(2) { top: 8px; }
  .hamburger span:nth-child(3) { top: 16px; }

  .menu-btn[aria-expanded="true"] .hamburger span:nth-child(1) {
    top: 8px;
    transform: rotate(45deg);
  }
  .menu-btn[aria-expanded="true"] .hamburger span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-btn[aria-expanded="true"] .hamburger span:nth-child(3) {
    top: 8px;
    transform: rotate(-45deg);
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    justify-self: center;
    text-decoration: none;
  }
  .wordmark-img {
    height: 42px;
    width: auto;
    display: block;
  }
  .wordmark-text {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    white-space: nowrap;
  }
  .wordmark-text em { font-style: normal; color: var(--color-accent); }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 28px;
    justify-self: end;
  }
  .search-icon {
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    transition: color var(--transition-fast);
  }
  .search-icon:hover { color: var(--color-accent); }

  .header-cta {
    padding: 12px 28px;
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: background 0.15s ease;
    display: inline-flex;
    align-items: center;
  }
  .header-cta:hover { background: var(--color-accent-hover); color: #fff; }

  /* ── Mega Menu (Mobile: Drawer / Desktop: Overlay) ── */

  .mega-menu {
    position: fixed;
    top: var(--header-height);
    left: 0;
    bottom: 0;
    background: var(--color-bg-white);
    z-index: 99;
    display: flex;
    flex-direction: column;

    /* Mobile: slide-in drawer */
    width: 85vw;
    max-width: 360px;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.12);
  }
  .mega-menu.is-open {
    transform: translateX(0);
  }

  .mega-menu-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 98;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    top: var(--header-height);
  }
  .mega-menu-backdrop.is-visible {
    opacity: 1;
    visibility: visible;
  }

  .mega-menu-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .mega-menu-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    background: var(--color-bg-subtle);
    border-radius: var(--radius-md);
    cursor: pointer;
    color: var(--color-text-primary);
    transition: all var(--transition-fast);
    flex-shrink: 0;
  }
  .mega-menu-close-btn:hover {
    background: var(--color-accent);
    color: var(--color-text-white);
  }

  .mega-menu-body {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 1.25rem 0 2rem;
  }

  .mega-direct-strip {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .mega-direct-pill {
    padding: 0.25rem 0.875rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    color: var(--color-text-body);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .mega-direct-pill:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .mega-direct-pill--active {
    background: var(--color-accent);
    color: var(--color-text-white);
    border-color: var(--color-accent);
  }
  .mega-direct-pill--active:hover {
    background: var(--color-accent-hover);
    color: var(--color-text-white);
  }

  .mega-menu-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mega-nav-primary {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mega-nav-accordion {
    border-bottom: 1px solid var(--color-border);
  }
  .mega-nav-accordion:last-child { border-bottom: none; }

  .mega-nav-accordion-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.75rem 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-primary);
    transition: color var(--transition-fast);
  }
  .mega-nav-accordion-trigger:hover { color: var(--color-accent); }

  .mega-nav-trigger-label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .mega-nav-trigger-label svg { color: var(--color-accent); flex-shrink: 0; }

  .accordion-chevron {
    color: var(--color-text-muted);
    transition: transform var(--transition-fast);
  }
  .is-expanded .accordion-chevron { transform: rotate(180deg); }

  .mega-nav-accordion-panel {
    display: none;
    padding-bottom: 0.75rem;
  }
  .is-expanded .mega-nav-accordion-panel { display: block; }

  .mega-nav-subsection { margin-bottom: 1rem; }
  .mega-nav-subsection:last-child { margin-bottom: 0; }

  .mega-nav-section-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }

  .mega-nav-subtitle {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .mega-nav-links {

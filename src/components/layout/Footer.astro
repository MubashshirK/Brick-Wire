---
import { NAV, SOCIAL, SITE } from '../../lib/constants';

const footerColumns = [
  {
    title: 'News',
    links: [
      { label: 'Latest Briefs', path: '/briefs/' },
      ...NAV.briefs.sectors.map(s => ({ label: s.label, path: s.path })),
    ],
  },
  {
    title: 'Reports',
    links: [
      { label: 'Market Reports', path: '/market-reports/' },
      { label: 'Reviews & Comparisons', path: '/reviews/' },
    ],
  },
  {
    title: 'Newsletters',
    links: [
      { label: 'All Newsletters', path: '/newsletters/' },
      ...NAV.newsletters.editions.map(e => ({ label: e.label, path: e.path })),
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Events', path: '/events/' },
      { label: 'CRE Terms Glossary', path: '/terms/' },
      { label: 'Search Partners', path: '/search-partners/' },
      { label: 'Podcast', path: '/podcast/' },
      { label: 'Fear & Greed Index', path: '/fear-greed-index/' },
    ],
  },
  {
    title: 'Company',
    links: [
      ...NAV.about,
      { label: 'Editorial Guidelines', path: '/editorial-guidelines/' },
      { label: 'Submit a Press Release', path: '#' },
    ],
  },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-brand">
      <div class="footer-brand-top">
        <a href="/" class="footer-wordmark" aria-label="Brick Wire home">
          <img src={SITE.logo} alt="Brick Wire" class="footer-logo" />
          <span class="footer-wordmark-text">Brick <em>Wire</em><sup>&reg;</sup></span>
        </a>
        <form class="footer-form" action="/api/subscribe" method="POST">
          <input type="hidden" name="form_location" value="footer" />
          <input type="hidden" name="publication" value="Brick Wire" />
          <label for="footer-sub-email" class="sr-only">Email address</label>
          <input id="footer-sub-email" name="email" type="email" placeholder="Your email address" required />
          <button type="submit" class="footer-form-btn">Subscribe</button>
        </form>
      </div>
      <p class="footer-desc">{SITE.description}</p>
      <p class="footer-privacy">Your privacy is our priority. Unsubscribe anytime.</p>
    </div>

    <div class="footer-grid">
      {footerColumns.map(col => (
        <div class="footer-col">
          <h4 class="footer-col-title">{col.title}</h4>
          <ul class="footer-links">
            {col.links.map(l => (
              <li><a href={l.path} {...(l.path.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <button class="footer-backtotop" type="button" id="footer-backtotop">
      <svg width="14" height="8" viewBox="0 0 14 8" fill="none">
        <path d="M1 7L7 1L13 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Back to top
    </button>

    <div class="footer-bottom">
      <div class="footer-contact">
        <a href={`mailto:${SITE.email}`} class="footer-contact-link">{SITE.email}</a>
        <span class="footer-contact-sep" aria-hidden="true">·</span>
        <span>{SITE.phone}</span>
      </div>
      <div class="footer-social">
        {SOCIAL.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="footer-social-link">
            {s.label === 'LinkedIn' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            )}
            {s.label === 'X (Twitter)' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            )}
            {s.label === 'Instagram' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            )}
            {s.label === 'Facebook' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            )}
            {s.label === 'YouTube' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            )}
          </a>
        ))}
      </div>
      <div class="footer-legal">
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/terms-of-service/">Terms of Service</a>
        <span class="footer-copyright">{SITE.copyright}</span>
      </div>
    </div>
  </div>
</footer>

<script>
  const btn = document.getElementById('footer-backtotop');
  if (btn) {
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<style>
  .site-footer {
    background: var(--color-bg-white);
    padding: var(--space-2xl) 0 0;
    font-size: var(--fs-body-small);
  }

  .footer-brand {
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-xl);
  }
  .footer-brand-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .footer-wordmark {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
  }
  .footer-logo {
    height: 42px;
    width: auto;
    display: block;
  }
  .footer-wordmark-text {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    white-space: nowrap;
  }
  .footer-wordmark-text em {
    font-style: normal;
    color: var(--color-accent);
  }
  .footer-wordmark-text sup {
    font-size: 0.5rem;
    font-weight: 600;
    vertical-align: super;
    color: var(--color-accent);
    margin-left: 2px;
  }

  .footer-desc {
    font-size: var(--fs-body-small);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 600px;
    margin: 0;
  }
  .footer-privacy {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    margin: 0.625rem 0 0;
  }

  .footer-form {
    display: flex;
    gap: 0;
    max-width: 420px;
  }
  .footer-form input[type="email"] {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-right: none;
    background: var(--color-bg-subtle);
    color: var(--color-text-primary);
    font-size: 0.9375rem;
    outline: none;
    min-width: 0;
    transition: border-color var(--transition-fast);
  }
  .footer-form input[type="email"]::placeholder {
    color: var(--color-text-muted);
  }
  .footer-form input[type="email"]:focus {
    border-color: var(--color-accent);
  }
  .footer-form-btn {
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-text-white);
    border: none;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background var(--transition-fast);
    white-space: nowrap;
  }
  .footer-form-btn:hover {
    background: var(--color-accent-hover);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem;
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }
  .footer-col-title {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
  }
  .footer-links a {
    color: var(--color-text-body);
    text-decoration: none;
    font-size: var(--fs-body-small);
    font-weight: 500;
    transition: color var(--transition-fast);
  }
  .footer-links a:hover {
    color: var(--color-accent);
  }

  .footer-backtotop {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: var(--space-md);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    transition: all var(--transition-fast);
  }
  .footer-backtotop:hover {
    color: var(--color-accent);
  }
  .footer-backtotop svg {
    transition: transform var(--transition-fast);
  }
  .footer-backtotop:hover svg {
    transform: translateY(-3px);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-xl);
    padding: var(--space-lg) 0;
  }
  .footer-contact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-size: var(--fs-body-small);
  }
  .footer-contact-link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer-contact-link:hover {
    color: var(--color-accent);
  }
  .footer-contact-sep {
    color: var(--color-border);
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
  }
  .footer-social-link {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    transition: color var(--transition-fast);
  }
  .footer-social-link:hover {
    color: var(--color-accent);
  }

  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
    font-size: var(--fs-body-small);
  }
  .footer-legal a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer-legal a:hover {
    color: var(--color-accent);
  }
  .footer-copyright {
    color: var(--color-text-muted);
  }

  @media (max-width: 75em) {
    .footer-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .footer-col:nth-child(5) {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 62em) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .footer-col:nth-child(4),
    .footer-col:nth-child(5) {
      grid-column: auto;
    }
  }
  @media (max-width: 48em) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
    .footer-brand-top {
      flex-direction: column;
      align-items: flex-start;
    }
    .footer-form {
      max-width: 100%;
      width: 100%;
    }
  }
  @media (max-width: 36em) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
    }
    .footer-logo { height: 32px; }
    .footer-wordmark-text { font-size: 1.25rem; }
  }
</style>

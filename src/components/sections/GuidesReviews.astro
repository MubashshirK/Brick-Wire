---
import { BUYERS_GUIDES } from '../../lib/constants';

const reviewProducts = [
  {
    name: 'Agora',
    slug: 'agora-review',
    svg: `<svg viewBox="0 0 140 50" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="25" cy="25" r="18" fill="#2563EB"/>
      <path d="M19 25l5 5 10-10" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      <text x="52" y="34" font-family="Inter, sans-serif" font-size="20" font-weight="900" fill="#111019">Agora</text>
    </svg>`,
  },
  {
    name: 'AirGarage',
    slug: 'airgarage-review',
    svg: `<svg viewBox="0 0 155 50" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="5" y="10" width="30" height="30" rx="5" fill="#f97316"/>
      <path d="M20 18v14M12 25h16" stroke="white" stroke-width="3" stroke-linecap="round"/>
      <text x="45" y="34" font-family="Inter, sans-serif" font-size="20" font-weight="900" fill="#111019">AirGarage</text>
    </svg>`,
  },
  {
    name: 'RE Analytics',
    slug: 're-analytics-review',
    svg: `<svg viewBox="0 0 175 50" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="5" y="8" width="34" height="34" rx="8" fill="#22c55e"/>
      <path d="M14 32l8-10 7 7 6-8" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <text x="48" y="34" font-family="Inter, sans-serif" font-size="19" font-weight="900" fill="#111019">RE Analytics</text>
    </svg>`,
  },
  {
    name: 'InvestNext',
    slug: 'investnext-review',
    svg: `<svg viewBox="0 0 165 50" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M25 10l14 28H11L25 10z" fill="#7c3aed"/>
      <path d="M25 18l7 14H18l7-14z" fill="white"/>
      <text x="48" y="34" font-family="Inter, sans-serif" font-size="19" font-weight="900" fill="#111019">InvestNext</text>
    </svg>`,
  },
  {
    name: 'RealtyMogul',
    slug: 'realtymogul-review',
    svg: `<svg viewBox="0 0 175 50" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="5" y="12" width="26" height="26" rx="4" fill="#0d9488"/>
      <path d="M10 25h16M18 19v12" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
      <text x="40" y="34" font-family="Inter, sans-serif" font-size="19" font-weight="900" fill="#111019">RealtyMogul</text>
    </svg>`,
  },
  {
    name: 'PropertyShark',
    slug: 'propertyshark-review',
    svg: `<svg viewBox="0 0 180 50" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M25 10l-15 10v15l15-5 15 5V20L25 10z" fill="#1e3a5f"/>
      <path d="M25 15l7 5-7 5-7-5 7-5z" fill="white"/>
      <text x="48" y="34" font-family="Inter, sans-serif" font-size="19" font-weight="900" fill="#111019">PropertyShark</text>
    </svg>`,
  },
  {
    name: 'CRED iQ',
    slug: 'cred-iq-review',
    svg: `<svg viewBox="0 0 115 50" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="5" y="10" width="32" height="30" rx="5" fill="#dc2626"/>
      <text x="12" y="33" font-family="Inter, sans-serif" font-size="16" font-weight="900" fill="white">CRED</text>
      <text x="44" y="34" font-family="Inter, sans-serif" font-size="20" font-weight="900" fill="#111019">iQ</text>
    </svg>`,
  },
  {
    name: 'Actovia',
    slug: 'actovia-review',
    svg: `<svg viewBox="0 0 130 50" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="25" cy="25" r="18" fill="#4f46e5"/>
      <path d="M18 25l5 5 9-9" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      <text x="50" y="34" font-family="Inter, sans-serif" font-size="20" font-weight="900" fill="#111019">Actovia</text>
    </svg>`,
  },
];
---

<section class="guides-section section-light section-padding">
  <div class="container">
    <div class="guides-header">
      <h2 class="guides-title">Guides &amp; Reviews</h2>
      <p class="guides-desc">Find and compare the best products and services in commercial real estate</p>
    </div>
    <div class="guides-grid">
      <div class="guides-column">
        <div class="guides-column-header">
          <div class="guides-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="12" y1="18" x2="12" y2="12"/>
              <line x1="9" y1="15" x2="15" y2="15"/>
            </svg>
          </div>
          <div>
            <h3>Buyers Guides</h3>
            <p class="guides-column-desc">A comprehensive overview of top picks in each category.</p>
          </div>
        </div>
        <ul class="guides-list">
          {BUYERS_GUIDES.slice(0, 6).map(g => (
            <li>
              <svg class="guides-star" width="16" height="16" viewBox="0 0 24 24" fill="var(--color-accent)"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
              <a href={g.path}>{g.title}</a>
            </li>
          ))}
        </ul>
        <a href="/reviews/" class="guides-cta-btn">BROWSE BUYERS GUIDES</a>
      </div>
      <div class="guides-column">
        <div class="guides-column-header">
          <div class="guides-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <div>
            <h3>Reviews</h3>
            <p class="guides-column-desc">We independently review each product so you can make confident buying decisions.</p>
          </div>
        </div>
        <div class="reviews-grid-logos">
          {reviewProducts.map(p => (
            <a href={`/reviews/${p.slug}/`} class="review-logo-item" set:html={p.svg} />
          ))}
        </div>
        <a href="/reviews/" class="guides-cta-btn">READ MORE REVIEWS</a>
      </div>
    </div>
  </div>
</section>

<style>
  .guides-section {
    /* No background - let grid show through */
  }
  .guides-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .guides-title {
    font-family: var(--font-heading);
    font-size: var(--fs-heading-2);
    font-weight: 900;
    margin-bottom: 0.5rem;
  }
  .guides-desc {
    color: var(--color-accent);
    font-size: 1.0625rem;
    font-weight: 500;
  }
  .guides-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .guides-column {
    background: var(--color-bg-white);
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
  }
  .guides-column-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .guides-icon {
    width: 56px;
    height: 56px;
    background: var(--color-bg-subtle);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .guides-icon svg {
    color: var(--color-accent);
  }
  .guides-column-header h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    font-style: italic;
    margin: 0 0 0.25rem 0;
  }
  .guides-column-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin: 0;
  }
  .guides-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
    margin-bottom: 1.5rem;
  }
  .guides-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .guides-list li:last-child {
    border-bottom: none;
  }
  .guides-star {
    flex-shrink: 0;
  }
  .guides-list li a {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .guides-list li a:hover {
    color: var(--color-accent);
  }
  .reviews-grid-logos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    flex: 1;
    margin-bottom: 1.5rem;
  }
  .review-logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: var(--color-bg-white);
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .review-logo-item :global(svg) {
    width: auto;
    height: 44px;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }

  .review-logo-item:hover :global(svg) {
    filter: grayscale(0%);
    opacity: 1;
  }
  .guides-cta-btn {
    display: block;
    width: 100%;
    padding: 1rem;
    background: var(--color-accent);
    color: var(--color-text-white);
    text-align: center;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .guides-cta-btn:hover {
    background: var(--color-accent-hover);
    color: var(--color-text-white);
  }
  @media (max-width: 48em) {
    .guides-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

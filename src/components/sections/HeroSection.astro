---
import TextSlider from '../blocks/TextSlider.astro';
import InboxMockup from '../blocks/InboxMockup.astro';
import { HERO_WORDS } from '../../lib/constants';
---

<section class="hero">
  <div class="hero__grid-bg"></div>
  <div class="hero__container">
    <div class="hero__grid">
      <!-- LEFT: Content -->
      <div class="hero__content">
        <p class="hero__eyebrow">Daily News in 5 Minutes or Less</p>

        <h1 class="hero__headline">
          Stay ahead of every<br/>
          <TextSlider words={HERO_WORDS} /><br/>
          in the market.
        </h1>

        <p class="hero__subtitle">
          Get the latest news and trends that shape the future of commercial real estate delivered to your inbox every morning in 5-minutes or less.
        </p>

        <form class="hero__form" action="/api/subscribe" method="POST">
          <input type="hidden" name="form_location" value="hero" />
          <input type="hidden" name="publication" value="Brick Wire" />
          <label for="hero-email" class="sr-only">Email address</label>
          <div class="hero__form-field">
            <svg class="hero__form-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <input id="hero-email" name="email" type="email" placeholder="Enter your email" required />
          </div>
          <button type="submit" class="hero__form-btn">SUBSCRIBE</button>
        </form>
      </div>

      <!-- RIGHT: Inbox + Phone -->
      <div class="hero__visual">
        <p class="hero__visual-label">Start your day with<br/><strong>Brick Wire's top news</strong> in your inbox.</p>
        <InboxMockup />
      </div>
    </div>

    <!-- Logo Bar -->
    <div class="hero__logos">
      <p class="hero__logos-text">Join <strong>65,000+</strong> professionals, developers, and investors from:</p>
      <div class="hero__logos-row">
        <span class="hero__logo" style="font-family: Georgia, serif; font-size: 1.25rem; font-weight: 700; letter-spacing: 0.05em;">CBRE</span>
        <span class="hero__logo" style="font-size: 1.125rem; font-weight: 800; letter-spacing: -0.02em;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style="vertical-align: middle; margin-right: 2px;"><circle cx="12" cy="12" r="10" stroke="#c41230" stroke-width="3" fill="none"/><circle cx="12" cy="12" r="4" fill="#c41230"/></svg>
          JLL
        </span>
        <span class="hero__logo" style="font-size: 1.125rem; font-weight: 700; color: #1a5276; letter-spacing: 0.02em;">Colliers</span>
        <span class="hero__logo" style="font-size: 1rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase;">PROLOGIS</span>
        <span class="hero__logo" style="font-size: 1rem; font-weight: 700; background: #111; color: #fff; padding: 4px 8px; border-radius: 2px;">Blackstone</span>
        <span class="hero__logo" style="font-size: 1.125rem; font-weight: 700; letter-spacing: 0.02em;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="vertical-align: middle; margin-right: 2px;"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          CoStar
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: calc(var(--header-height) + 2.5rem) 0 3rem;
    background: #fff;
    overflow: clip;
  }

  .hero__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-xl);
    overflow: visible;
    position: relative;
    z-index: 1;
  }

  /* ── Grid ── */
  .hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 62em) {
    .hero__grid {
      grid-template-columns: 0.52fr 1fr;
      gap: 2rem;
      align-items: start;
    }
  }

  /* ── Content (Left) ── */
  .hero__content {
    order: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero__eyebrow {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
    margin: 0;
  }

  .hero__headline {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 900;
    line-height: 1.05;
    color: #111;
    margin: 0.25rem 0 0;
    letter-spacing: -0.02em;
  }

  .hero__headline :global(.text-slider) {
    font-family: var(--font-heading);
    font-size: inherit;
    font-weight: 900;
    color: var(--color-accent);
  }

  .hero__subtitle {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: #4b5563;
    max-width: 95%;
    margin: 0.5rem 0 0;
  }

  /* ── Form ── */
  .hero__form {
    display: flex;
    gap: 0;
    max-width: 580px;
    margin-top: 0.5rem;
  }

  .hero__form-field {
    flex: 1;
    display: flex;
    align-items: center;
    border: 2px solid #e5e7eb;
    border-right: none;
    background: #fff;
    transition: border-color 0.15s ease;
    border-radius: 8px 0 0 8px;
  }

  .hero__form-field:focus-within {
    border-color: var(--color-accent);
  }

  .hero__form-icon {
    flex-shrink: 0;
    margin-left: 1rem;
    color: #9ca3af;
  }

  .hero__form-field input {
    flex: 1;
    padding: 1rem 0.875rem;
    border: none;
    font-size: 1rem;
    background: transparent;
    outline: none;
    color: #111;
  }

  .hero__form-field input::placeholder {
    color: #9ca3af;
  }

  .hero__form-btn {
    padding: 1rem 1.75rem;
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: 0 8px 8px 0;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .hero__form-btn:hover {
    background: var(--color-accent-hover);
  }

  /* ── Visual (Right) ── */
  .hero__visual {
    order: 2;
    position: relative;
    margin-top: 40px;
  }

  .hero__visual-label {
    font-size: 0.8125rem;
    color: #374151;
    margin-bottom: 0.75rem;
    line-height: 1.5;
    margin-left: 80px;
  }

  .hero__visual-label strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ── Logo Bar ── */
  .hero__logos {
    padding-top: 2rem;
  }

  .hero__logos-text {
    font-size: 0.875rem;
    color: #6b7280;
    margin-bottom: 1.25rem;
  }

  .hero__logos-text strong {
    color: #111;
    font-weight: 700;
  }

  .hero__logos-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
  }

  .hero__logo {
    opacity: 0.45;
    transition: opacity 0.15s ease;
    display: inline-flex;
    align-items: center;
    color: #374151;
  }

  .hero__logo:hover {
    opacity: 0.8;
  }

  /* ── Mobile ── */
  @media (max-width: 48em) {
    .hero {
      padding: calc(var(--header-height) + 1.5rem) 0 2rem;
    }

    .hero__headline {
      font-size: 2.25rem;
    }

    .hero__subtitle {
      max-width: 100%;
    }

    .hero__form {
      flex-direction: column;
      gap: 0.75rem;
      max-width: 100%;
    }

    .hero__form-field {
      border-right: 2px solid #e5e7eb;
      border-radius: 8px;
    }

    .hero__form-field:focus-within {
      border-right-color: var(--color-accent);
    }

    .hero__form-btn {
      border-radius: 8px;
      width: 100%;
    }

    .hero__logos-row {
      gap: 1.25rem;
    }
  }
</style>

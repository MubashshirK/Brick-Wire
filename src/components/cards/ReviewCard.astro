---
interface Props {
  title: string;
  slug: string;
  productName: string;
  rating: number;
  author: string;
  date: string;
  image?: string;
}
const { title, slug, productName, rating, author, date, image } = Astro.props;
---

<article class="review-card">
  <a href={`/reviews/${slug}/`} class="review-card-link">
    <div class="review-card-image">
      {image ? (
        <img src={image} alt={productName} loading="lazy" />
      ) : (
        <div class="review-card-placeholder">
          <span>{productName?.charAt(0)}</span>
        </div>
      )}
    </div>
    <div class="review-card-body">
      <h3 class="review-card-title">{title}</h3>
      <div class="review-stars">
        {[...Array(5)].map((_, i) => (
          <svg width="14" height="14" viewBox="0 0 14 14" fill={i < rating ? 'var(--color-accent)' : 'var(--color-border)'}>
            <path d="M7 0l1.96 4.46 4.79.56-3.5 3.39.87 4.99L7 10.5l-4.12 2.9.87-4.99-3.5-3.39 4.79-.56L7 0z"/>
          </svg>
        ))}
      </div>
      <p class="review-card-meta">By {author} &middot; {date}</p>
    </div>
  </a>
</article>

<style>
  .review-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: box-shadow var(--transition-fast);
  }
  .review-card:hover {
    box-shadow: var(--shadow-md);
  }
  .review-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .review-card-image {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .review-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .review-card-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-light);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .review-card-placeholder span {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent);
    opacity: 0.5;
  }
  .review-card-body {
    padding: 1rem;
  }
  .review-card-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }
  .review-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 0.5rem;
  }
  .review-card-meta {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>

---
import { urlFor } from '../../lib/sanity';
import type { SanityImage } from '../../lib/sanity';
interface Props {
  title: string;
  slug: string;
  edition: string;
  date: string;
  excerpt?: string;
  image?: SanityImage;
}
const { title, slug, edition, date, excerpt, image } = Astro.props;
---

<article class="newsletter-card">
  <a href={`/newsletters/${edition}/issue/${slug}/`} class="newsletter-card-link">
    <div class="newsletter-card-image">
      {image
        ? <img src={urlFor(image).width(400).url()} alt={title} class="newsletter-card-img" />
        : <div class="newsletter-card-placeholder"></div>
      }
    </div>
    <div class="newsletter-card-body">
      <span class="newsletter-edition">{edition}</span>
      <h3 class="newsletter-card-title">{title}</h3>
      {excerpt && <p class="newsletter-card-excerpt">{excerpt}</p>}
      <time class="newsletter-card-date">{date}</time>
    </div>
  </a>
</article>

<style>
  .newsletter-card {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .newsletter-card-link {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: opacity var(--transition-fast);
  }
  .newsletter-card-link:hover { opacity: 0.85; }
  .newsletter-card-placeholder {
    width: 100%;
    padding-bottom: 52%;
    background: var(--color-bg-subtle);
    border-radius: 0.5rem;
  }
  .newsletter-card-image {
    position: relative;
    overflow: hidden;
  }
  .newsletter-card-img {
    width: 100%;
    aspect-ratio: 1.92 / 1;
    object-fit: cover;
    border-radius: 0.5rem;
    display: block;
  }
  .newsletter-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .newsletter-edition {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .newsletter-card-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .newsletter-card-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .newsletter-card-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  @media (max-width: 48em) {
    .newsletter-card-link {
      grid-template-columns: 1fr;
    }
  }
</style>

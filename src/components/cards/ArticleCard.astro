---
interface Props {
  title: string;
  slug: string;
  date: string;
  category?: string;
  excerpt?: string;
  sponsored?: { name: string };
  image?: string;
}
const { title, slug, date, category, excerpt, sponsored, image } = Astro.props;
---

<article class="article-card">
  <a href={`/briefs/${slug}/`} class="article-card-link">
    <div class="article-card-image">
      {Astro.props.image ? (
        <img src={image} alt={title} loading="lazy" />
      ) : (
        <div class="article-card-placeholder"></div>
      )}
    </div>
    <div class="article-card-body">
      {sponsored && <span class="article-sponsored">Sponsored</span>}
      {category && <span class="article-category">{category}</span>}
      <h3 class="article-card-title">{title}</h3>
      {excerpt && <p class="article-card-excerpt">{excerpt}</p>}
      <time class="article-card-date">{date}</time>
    </div>
  </a>
</article>

<style>
  .article-card {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .article-card-link {
    display: flex;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: opacity var(--transition-fast);
  }
  .article-card-link:hover { opacity: 0.85; }
  .article-card-image {
    width: 160px;
    flex-shrink: 0;
  }
  .article-card-placeholder {
    width: 100%;
    padding-bottom: 67%;
    background: var(--color-bg-subtle);
    border-radius: 0.5rem;
  }
  .article-card-image img {
    width: 100%;
    aspect-ratio: 3/2;
    object-fit: cover;
    border-radius: 0.5rem;
  }
  .article-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .article-sponsored {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .article-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .article-card-title {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text-primary);
  }
  .article-card-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .article-card-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  @media (max-width: 48em) {
    .article-card-link {
      flex-direction: column;
    }
    .article-card-image {
      width: 100%;
    }
  }
</style>

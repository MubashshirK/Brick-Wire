---
import PageLayout from '../../../../layouts/PageLayout.astro';
import { client, NEWSLETTERS_QUERY, NEWSLETTER_QUERY, toHTMLBody } from '../../../../lib/sanity';
import type { Newsletter } from '../../../../lib/sanity';
export async function getStaticPaths() {
  const newsletters: Newsletter[] = await client.fetch(NEWSLETTERS_QUERY);
  return newsletters.map(n => ({ params: { edition: n.edition, slug: n.slug.current } }));
}
const { edition, slug } = Astro.params;
const issue: Newsletter = await client.fetch(NEWSLETTER_QUERY, { slug });
const editionName = issue.edition.charAt(0).toUpperCase() + issue.edition.slice(1).replace('-', ' ');
const bodyHTML = toHTMLBody(issue.body);
const issueDate = new Date(issue.issueDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<PageLayout title={issue.title}>
  <article class="issue-page section-padding">
    <div class="container" style="max-width: var(--container-narrow);">
      <div class="issue-meta">
        <span class="issue-edition">{editionName} Edition</span>
        <time>{issueDate}</time>
      </div>
      <h1 class="issue-title">{issue.title}</h1>
      <div class="issue-body" set:html={bodyHTML}></div>
      <div class="issue-footer">
        <p>Thank you for reading the {issue.edition} edition of the Brick Wire newsletter.</p>
      </div>
    </div>
  </article>
</PageLayout>

<style>
  .issue-page { padding-top: calc(var(--header-height) + 2rem); }
  .issue-meta { display: flex; gap: 1rem; margin-bottom: 1rem; }
  .issue-edition { font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; color: var(--color-accent); }
  .issue-meta time { font-size: 0.875rem; color: var(--color-text-muted); }
  .issue-title { font-size: var(--fs-heading-1); line-height: 1.15; margin-bottom: 2rem; }
  .issue-body p { font-size: 1.125rem; line-height: 1.8; margin-bottom: 1.5rem; color: var(--color-text-body); }
  .issue-body h2 { font-family: var(--font-heading); font-size: 1.5rem; margin: 2rem 0 1rem; }
  .issue-body ul { margin-bottom: 1.5rem; padding-left: 1.5rem; }
  .issue-body li { font-size: 1.125rem; line-height: 1.8; color: var(--color-text-body); }
  .issue-footer { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .issue-footer p { font-size: 0.9375rem; color: var(--color-text-muted); }
</style>

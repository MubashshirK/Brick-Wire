---
import PageLayout from '../../layouts/PageLayout.astro';
import { client, EVENTS_QUERY, urlFor } from '../../lib/sanity';
import type { Event } from '../../lib/sanity';

const allEvents: Event[] = await client.fetch(EVENTS_QUERY);
const today = new Date();
today.setHours(0, 0, 0, 0);

const upcoming = allEvents.filter(e => new Date(e.date) >= today);
const past = allEvents.filter(e => new Date(e.date) < today);
---

<PageLayout title="Events" description="Upcoming commercial real estate events, webinars, and networking opportunities curated by Brick Wire.">
  <section class="events-page section-padding">
    <div class="container">
      <div class="events-header">
        <h1>Events</h1>
        <p class="events-subtitle">Stay connected with the CRE community. Browse upcoming and past events, webinars, and industry gatherings.</p>
      </div>

      {upcoming.length > 0 ? (
        <div class="events-section">
          <div class="events-section-heading">
            <h2>Upcoming Events</h2>
            <span class="events-count">{upcoming.length} event{upcoming.length !== 1 ? 's' : ''}</span>
          </div>
          <div class="events-grid">
            {upcoming.map(event => (
              <a href={event.link || '#'} target={event.link ? '_blank' : '_self'} rel="noopener noreferrer" class="event-card event-card--upcoming">
                <div class="event-card-image">
                  {event.image ? (
                    <img src={urlFor(event.image).width(600).height(340).url()} alt={event.title} loading="lazy" />
                  ) : (
                    <div class="event-card-placeholder">
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                      </svg>
                    </div>
                  )}
                  <div class="event-card-date-badge">
                    <span class="event-date-month">{new Date(event.date).toLocaleDateString('en-US', { month: 'short' })}</span>
                    <span class="event-date-day">{new Date(event.date).getDate()}</span>
                  </div>
                </div>
                <div class="event-card-body">
                  <h3 class="event-card-title">{event.title}</h3>
                  <div class="event-card-meta">
                    {event.location && (
                      <span class="event-meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        {event.location}
                      </span>
                    )}
                    <span class="event-meta-item">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      {new Date(event.date).toLocaleDateString('en-US', { weekday: 'long', hour: 'numeric', minute: '2-digit' })}
                    </span>
                  </div>
                  {event.description && <p class="event-card-desc">{event.description.substring(0, 150)}{event.description.length > 150 ? '...' : ''}</p>}
                  {event.link && <span class="event-card-cta">Learn More <span class="event-arrow">&rarr;</span></span>}
                </div>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class="events-empty">
          <div class="events-empty-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <h2>No upcoming events</h2>
          <p>Check back soon for upcoming events, webinars, and networking opportunities. In the meantime, explore our <a href="/briefs/">latest briefs</a> or <a href="/podcast/">podcast episodes</a>.</p>
        </div>
      )}

      {past.length > 0 && (
        <div class="events-section events-section--past">
          <div class="events-section-heading">
            <h2>Past Events</h2>
            <span class="events-count">{past.length} event{past.length !== 1 ? 's' : ''}</span>
          </div>
          <div class="events-past-list">
            {past.map(event => (
              <a href={event.link || '#'} target={event.link ? '_blank' : '_self'} rel="noopener noreferrer" class="event-past-card">
                <div class="event-past-date">
                  <span class="event-past-month">{new Date(event.date).toLocaleDateString('en-US', { month: 'short' })}</span>
                  <span class="event-past-day">{new Date(event.date).getDate()}</span>
                  <span class="event-past-year">{new Date(event.date).getFullYear()}</span>
                </div>
                <div class="event-past-body">
                  <h3 class="event-past-title">{event.title}</h3>
                  {event.location && <span class="event-past-location">{event.location}</span>}
                </div>
                {event.link && <span class="event-past-cta">View<span class="event-arrow">&rarr;</span></span>}
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="events-cta section-subtle">
        <div class="events-cta-content">
          <h2>Stay informed about CRE events</h2>
          <p>Get notified about upcoming events, webinars, and industry conferences delivered to your inbox.</p>
          <a href="/newsletter-signup/" class="btn btn-primary">Subscribe to Newsletter</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .events-page { padding-top: calc(var(--header-height) + 2rem); }
  .events-header { margin-bottom: 3rem; }
  .events-header h1 { font-family: var(--font-heading); font-size: var(--fs-heading-1); margin-bottom: 0.75rem; }
  .events-subtitle { font-size: 1.125rem; color: var(--color-text-muted); max-width: 36rem; line-height: 1.6; }

  .events-section { margin-bottom: 4rem; }
  .events-section--past { opacity: 0.85; }
  .events-section-heading {
    display: flex; align-items: baseline; gap: 1rem;
    margin-bottom: 1.5rem; padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-accent);
  }
  .events-section-heading h2 { font-family: var(--font-heading); font-size: 1.5rem; }
  .events-count { font-size: 0.875rem; color: var(--color-text-muted); font-weight: 600; }

  .events-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 1.5rem; }

  .event-card {
    display: flex; flex-direction: column;
    border: 1px solid var(--color-border); border-radius: var(--radius-lg);
    overflow: hidden; text-decoration: none; color: inherit;
    transition: box-shadow var(--transition-fast), transform var(--transition-fast);
  }
  .event-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .event-card-image { position: relative; aspect-ratio: 16/9; overflow: hidden; background: var(--color-bg-subtle); }
  .event-card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .event-card:hover .event-card-image img { transform: scale(1.03); }
  .event-card-placeholder {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    color: var(--color-text-muted); opacity: 0.4;
  }
  .event-card-date-badge {
    position: absolute; top: 1rem; left: 1rem;
    display: flex; flex-direction: column; align-items: center;
    background: var(--color-bg-white); border-radius: var(--radius-md);
    padding: 0.375rem 0.75rem; box-shadow: var(--shadow-md);
    line-height: 1.2;
  }
  .event-date-month { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; color: var(--color-accent); }
  .event-date-day { font-size: 1.25rem; font-weight: 800; color: var(--color-text-primary); font-family: var(--font-heading); }
  .event-card-body { padding: 1.25rem; flex: 1; display: flex; flex-direction: column; gap: 0.625rem; }
  .event-card-title { font-family: var(--font-heading); font-size: 1.125rem; font-weight: 700; line-height: 1.3; }
  .event-card:hover .event-card-title { color: var(--color-accent); }
  .event-card-meta { display: flex; flex-direction: column; gap: 0.375rem; }
  .event-meta-item { display: flex; align-items: center; gap: 0.375rem; font-size: 0.8125rem; color: var(--color-text-muted); }
  .event-meta-item svg { flex-shrink: 0; color: var(--color-accent); }
  .event-card-desc { font-size: 0.875rem; color: var(--color-text-body); line-height: 1.55; flex: 1; }
  .event-card-cta { font-size: 0.8125rem; font-weight: 700; color: var(--color-accent); display: flex; align-items: center; gap: 0.375rem; }
  .event-arrow { transition: transform var(--transition-fast); }
  .event-card:hover .event-arrow { transform: translateX(3px); }

  .events-empty { text-align: center; padding: 4rem 2rem; }
  .events-empty-icon { display: flex; justify-content: center; margin-bottom: 1.25rem; color: var(--color-text-muted); opacity: 0.5; }
  .events-empty h2 { font-family: var(--font-heading); font-size: 1.5rem; margin-bottom: 0.625rem; }
  .events-empty p { font-size: 0.9375rem; color: var(--color-text-muted); max-width: 480px; margin: 0 auto; line-height: 1.65; }
  .events-empty a { color: var(--color-accent); font-weight: 600; }
  .events-empty a:hover { text-decoration: underline; }

  .events-past-list { display: flex; flex-direction: column; }
  .event-past-card {
    display: flex; align-items: center; gap: 1.25rem;
    padding: 1rem 0; border-bottom: 1px solid var(--color-border);
    text-decoration: none; color: inherit; transition: opacity var(--transition-fast);
  }
  .event-past-card:hover { opacity: 0.8; }
  .event-past-card:last-child { border-bottom: none; }
  .event-past-date {
    display: flex; flex-direction: column; align-items: center;
    min-width: 3.5rem; line-height: 1.15;
  }
  .event-past-month { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; color: var(--color-accent); }
  .event-past-day { font-size: 1.25rem; font-weight: 800; font-family: var(--font-heading); color: var(--color-text-primary); }
  .event-past-year { font-size: 0.75rem; color: var(--color-text-muted); }
  .event-past-body { flex: 1; }
  .event-past-title { font-size: 1rem; font-weight: 600; line-height: 1.3; }
  .event-past-location { font-size: 0.8125rem; color: var(--color-text-muted); }
  .event-past-cta { font-size: 0.8125rem; font-weight: 700; color: var(--color-accent); display: flex; align-items: center; gap: 0.375rem; flex-shrink: 0; }

  .events-cta { margin-top: 3rem; padding: 3rem; border-radius: var(--radius-lg); text-align: center; }
  .events-cta-content { max-width: 480px; margin: 0 auto; }
  .events-cta-content h2 { font-family: var(--font-heading); font-size: 1.5rem; margin-bottom: 0.75rem; }
  .events-cta-content p { font-size: 1rem; color: var(--color-text-muted); margin-bottom: 1.5rem; line-height: 1.6; }

  @media (max-width: 48em) {
    .events-grid { grid-template-columns: 1fr; }
    .event-past-card { flex-wrap: wrap; gap: 0.75rem; }
    .event-past-cta { width: 100%; justify-content: flex-end; }
    .events-cta { padding: 2rem 1.5rem; }
  }
</style>

---
import PageLayout from '../../layouts/PageLayout.astro';
export async function getStaticPaths() {
  const sectors = ['industry-news', 'investments', 'multifamily', 'industrial', 'proptech', 'lending', 'office', 'retail', 'data'];
  return sectors.map(sector => ({ params: { sector } }));
}
const { sector } = Astro.params;
const sectorName = sector ? sector.split('-').map(s => s.charAt(0).toUpperCase() + s.slice(1)).join(' ') : '';
---

<PageLayout title={`${sectorName} Briefs`}>
  <section class="section-padding">
    <div class="container">
      <h1 style="font-size: var(--fs-heading-1); margin-bottom: 2rem;">{sectorName}</h1>
      <p style="color: var(--color-text-muted); margin-bottom: 2rem;">The latest news and trends in {sectorName}.</p>
      <div class="briefs-list">
        <!-- Briefs filtered by sector would render here -->
      </div>
    </div>
  </section>
</PageLayout>

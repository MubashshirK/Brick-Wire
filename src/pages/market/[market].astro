---
import PageLayout from '../../layouts/PageLayout.astro';
import ArticleCard from '../../components/cards/ArticleCard.astro';
import { client, BRIEFS_BY_MARKET_QUERY } from '../../lib/sanity';
import type { Brief } from '../../lib/sanity';
export async function getStaticPaths() {
  return ['national', 'texas', 'california', 'new-york', 'florida'].map(market => ({
    params: { market },
  }));
}
const { market } = Astro.params;
const marketName = market ? market.charAt(0).toUpperCase() + market.slice(1).replace('-', ' ') : '';
const briefs: Brief[] = await client.fetch(BRIEFS_BY_MARKET_QUERY, { market });
---

<PageLayout title={`${marketName} Market Briefs`}>
  <section class="section-padding">
    <div class="container">
      <h1 style="font-size: var(--fs-heading-1); margin-bottom: 2rem;">{marketName} Market Briefs</h1>
      <p style="color: var(--color-text-muted); margin-bottom: 2rem;">The latest real estate news and trends from the {marketName} market.</p>
      <div class="briefs-list">
        {briefs.map(b => <ArticleCard title={b.title} slug={b.slug.current} date={b.date} category={b.sector?.name} excerpt={b.excerpt} />)}
      </div>
    </div>
  </section>
</PageLayout>

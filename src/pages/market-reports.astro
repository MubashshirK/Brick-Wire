---
import PageLayout from '../layouts/PageLayout.astro';
import { client, MARKET_REPORTS_QUERY } from '../lib/sanity';
import type { MarketReport } from '../lib/sanity';

const reports: MarketReport[] = await client.fetch(MARKET_REPORTS_QUERY);
---

<PageLayout title="Market Reports" description="Quarterly and special reports on commercial real estate market conditions across the United States.">
  <section class="section-padding">
    <div class="container">
      <h1 style="font-size: var(--fs-heading-1); margin-bottom: 0.5rem;">Market Reports</h1>
      <p style="color: var(--color-text-muted); margin-bottom: 2rem;">Quarterly and special reports on CRE market conditions across the US.</p>
      <div class="reports-grid">
        {reports.map(r => (
          <div class="report-card">
            <div class="report-type">{r.assetClass || 'Report'}</div>
            <h3 class="report-title">{r.title}</h3>
            <div class="report-date">{r.publisher ? `${r.publisher} · ` : ''}{new Date(r.reportDate).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</div>
            <a href="#" class="report-download">Download PDF</a>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .reports-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .report-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: box-shadow var(--transition-fast);
  }
  .report-card:hover { box-shadow: var(--shadow-md); }
  .report-type {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }
  .report-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .report-date { font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 1rem; }
  .report-download {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }
  .report-download:hover { text-decoration: underline; }
</style>

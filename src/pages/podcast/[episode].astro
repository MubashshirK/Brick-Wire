---
import PageLayout from '../../layouts/PageLayout.astro';
export async function getStaticPaths() {
  return [
    { params: { episode: '102' } },
    { params: { episode: '101' } },
  ];
}
const { episode } = Astro.params;
---

<PageLayout title="No Cap Episode">
  <article class="episode-page section-padding">
    <div class="container" style="max-width: var(--container-narrow);">
      <div class="episode-player">
        <div class="player-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span>Episode #{episode}</span>
        </div>
      </div>
      <h1 class="episode-page-title">The Future of Office: Flexible, Amenitized, and Smaller</h1>
      <div class="episode-page-meta">July 8, 2026 &middot; Guest: Sarah Chen, CBRE</div>
      <div class="episode-page-body">
        <p>In this episode of No Cap by Brick Wire, we sit down with Sarah Chen of CBRE to discuss the evolving office landscape and what tenants are really looking for in 2026 and beyond.</p>
        <p>From flexible lease terms to amenity-rich environments, we explore how office landlords are adapting to the new normal of hybrid work.</p>
      </div>
    </div>
  </article>
</PageLayout>

<style>
  .episode-page { padding-top: calc(var(--header-height) + 2rem); }
  .player-placeholder {
    width: 100%;
    padding: 3rem;
    background: var(--color-bg-subtle);
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  .episode-page-title { font-size: var(--fs-heading-1); line-height: 1.15; margin-bottom: 0.75rem; }
  .episode-page-meta { font-size: 0.9375rem; color: var(--color-text-muted); margin-bottom: 2rem; }
  .episode-page-body p { font-size: 1.125rem; line-height: 1.8; margin-bottom: 1.5rem; color: var(--color-text-body); }
</style>

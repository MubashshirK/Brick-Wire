---
import PageLayout from '../../layouts/PageLayout.astro';
import { client, PODCAST_EPISODES_QUERY, PODCAST_EPISODE_QUERY } from '../../lib/sanity';
import type { PodcastEpisode } from '../../lib/sanity';
export async function getStaticPaths() {
  const episodes: PodcastEpisode[] = await client.fetch(PODCAST_EPISODES_QUERY);
  return episodes.map(ep => ({ params: { episode: ep.slug.current } }));
}
const { episode } = Astro.params;
const ep: PodcastEpisode = await client.fetch(PODCAST_EPISODE_QUERY, { slug: episode });
const episodeDate = new Date(ep.episodeDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<PageLayout title={ep.title}>
  <article class="episode-page section-padding">
    <div class="container" style="max-width: var(--container-narrow);">
      <div class="episode-player">
        <div class="player-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span>Listen to Episode</span>
        </div>
      </div>
      <h1 class="episode-page-title">{ep.title}</h1>
      <div class="episode-page-meta">{episodeDate} &middot; Guest: {ep.guest}</div>
      {ep.description && <div class="episode-page-body"><p>{ep.description}</p></div>}
      {(ep.spotifyUrl || ep.appleUrl || ep.youtubeUrl) && (
        <div class="episode-platform-links" style="display:flex;gap:0.75rem;margin-top:1.5rem;">
          {ep.spotifyUrl && <a href={ep.spotifyUrl} class="btn btn-secondary" target="_blank">Listen on Spotify</a>}
          {ep.appleUrl && <a href={ep.appleUrl} class="btn btn-secondary" target="_blank">Listen on Apple</a>}
          {ep.youtubeUrl && <a href={ep.youtubeUrl} class="btn btn-secondary" target="_blank">Watch on YouTube</a>}
        </div>
      )}
    </div>
  </article>
</PageLayout>

<style>
  .episode-page { padding-top: calc(var(--header-height) + 2rem); }
  .player-placeholder {
    width: 100%;
    padding: 3rem;
    background: var(--color-bg-subtle);
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  .episode-page-title { font-size: var(--fs-heading-1); line-height: 1.15; margin-bottom: 0.75rem; }
  .episode-page-meta { font-size: 0.9375rem; color: var(--color-text-muted); margin-bottom: 2rem; }
  .episode-page-body p { font-size: 1.125rem; line-height: 1.8; margin-bottom: 1.5rem; color: var(--color-text-body); }
</style>

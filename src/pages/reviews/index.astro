---
import PageLayout from '../../layouts/PageLayout.astro';
import ReviewCard from '../../components/cards/ReviewCard.astro';
import { client, REVIEWS_QUERY } from '../../lib/sanity';
import type { Review } from '../../lib/sanity';

const reviews: Review[] = await client.fetch(REVIEWS_QUERY);
---

<PageLayout title="Product Reviews" description="In-depth reviews of the leading commercial real estate software platforms and services.">
  <section class="reviews-page section-padding">
    <div class="container">
      <h1 style="font-size: var(--fs-heading-1); margin-bottom: 0.5rem;">Reviews</h1>
      <p style="color: var(--color-text-muted); margin-bottom: 2rem;">Honest, in-depth reviews of the leading CRE software platforms and services.</p>
      <div class="reviews-grid">
        {reviews.map(r => <ReviewCard title={r.title} slug={r.slug.current} productName={r.productName} rating={r.rating} author={r.author} date={r.date} />)}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
</style>

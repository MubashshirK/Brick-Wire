---
import PageLayout from '../../layouts/PageLayout.astro';
import { client, REVIEWS_QUERY, REVIEW_QUERY, urlFor, toHTMLBody } from '../../lib/sanity';
import type { Review } from '../../lib/sanity';
export async function getStaticPaths() {
  const reviews: Review[] = await client.fetch(REVIEWS_QUERY);
  return reviews.map(r => ({ params: { slug: r.slug.current } }));
}
const { slug } = Astro.params;
const review: Review = await client.fetch(REVIEW_QUERY, { slug });
const bodyHTML = toHTMLBody(review.body);
---

<PageLayout title={review.title}>
  <article class="review-page section-padding">
    <div class="container" style="max-width: var(--container-narrow);">
      <div class="review-stars-large">
        {[...Array(5)].map((_, i) => (
          <svg width="20" height="20" viewBox="0 0 14 14" fill={i < review.rating ? 'var(--color-accent)' : 'var(--color-border)'}>
            <path d="M7 0l1.96 4.46 4.79.56-3.5 3.39.87 4.99L7 10.5l-4.12 2.9.87-4.99-3.5-3.39 4.79-.56L7 0z"/>
          </svg>
        ))}
      </div>
      <h1 class="review-title">{review.title}</h1>
      <div class="review-meta">By {review.author} &middot; {review.date}</div>
      <div class="review-hero">
        {review.image ? (
          <img src={urlFor(review.image).width(800).url()} alt={review.productName} style="width:100%;border-radius:1rem;margin-bottom:2rem;" />
        ) : (
          <div class="review-hero-placeholder"></div>
        )}
      </div>
      <div class="review-body" set:html={bodyHTML}></div>
      {review.pros && review.pros.length > 0 && (
        <>
          <h2>Pros</h2>
          <ul>{review.pros.map(p => <li>{p}</li>)}</ul>
        </>
      )}
      {review.cons && review.cons.length > 0 && (
        <>
          <h2>Cons</h2>
          <ul>{review.cons.map(c => <li>{c}</li>)}</ul>
        </>
      )}
    </div>
  </article>
</PageLayout>

<style>
  .review-page { padding-top: calc(var(--header-height) + 2rem); }
  .review-stars-large { display: flex; gap: 4px; margin-bottom: 1rem; }
  .review-title { font-size: var(--fs-heading-1); line-height: 1.15; margin-bottom: 1rem; }
  .review-meta { font-size: 0.9375rem; color: var(--color-text-muted); margin-bottom: 2rem; }
  .review-hero-placeholder {
    width: 100%;
    padding-bottom: 52%;
    background: var(--color-bg-subtle);
    border-radius: 1rem;
    margin-bottom: 2rem;
  }
  .review-body p { font-size: 1.125rem; line-height: 1.8; margin-bottom: 1.5rem; color: var(--color-text-body); }
  .review-body h2 { font-family: var(--font-heading); font-size: 1.5rem; margin: 2rem 0 1rem; }
  .review-body ul { margin-bottom: 1.5rem; padding-left: 1.5rem; }
  .review-body li { font-size: 1.125rem; line-height: 1.8; color: var(--color-text-body); }
</style>

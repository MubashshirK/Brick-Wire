---
import PageLayout from '../../layouts/PageLayout.astro';
import ArticleCard from '../../components/cards/ArticleCard.astro';
import { client, BRIEFS_QUERY } from '../../lib/sanity';
import type { Brief } from '../../lib/sanity';

const briefs: Brief[] = await client.fetch(BRIEFS_QUERY);
---

<PageLayout title="Latest Briefs" description="Stay up to date with the latest commercial real estate news, transactions, and trends.">
  <section class="briefs-page section-padding">
    <div class="container">
      <div class="briefs-header">
        <h1>Latest Briefs</h1>
        <div class="briefs-filters">
          <div class="filter-group">
            <span class="filter-label">Markets</span>
            <div class="filter-tags">
              <a href="/market/national/" class="filter-tag">National</a>
              <a href="/market/texas/" class="filter-tag">Texas</a>
              <a href="/market/california/" class="filter-tag">California</a>
              <a href="/market/new-york/" class="filter-tag">New York</a>
              <a href="/market/florida/" class="filter-tag">Florida</a>
            </div>
          </div>
          <div class="filter-group">
            <span class="filter-label">Sectors</span>
            <div class="filter-tags">
              <a href="/sectors/industry-news/" class="filter-tag">Industry News</a>
              <a href="/sectors/investments/" class="filter-tag">Investments</a>
              <a href="/sectors/multifamily/" class="filter-tag">Multifamily</a>
              <a href="/sectors/industrial/" class="filter-tag">Industrial</a>
              <a href="/sectors/proptech/" class="filter-tag">Proptech</a>
              <a href="/sectors/lending/" class="filter-tag">Lending</a>
              <a href="/sectors/office/" class="filter-tag">Office</a>
              <a href="/sectors/retail/" class="filter-tag">Retail</a>
              <a href="/sectors/data/" class="filter-tag">Data</a>
            </div>
          </div>
        </div>
      </div>
      <div class="briefs-list">
        {briefs.map(s => <ArticleCard title={s.title} slug={s.slug.current} date={s.date} category={s.sector?.name} excerpt={s.excerpt} />)}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .briefs-header {
    margin-bottom: 2.5rem;
  }
  .briefs-header h1 {
    font-family: var(--font-heading);
    font-size: var(--fs-heading-1);
    margin-bottom: 1.5rem;
  }
  .briefs-filters {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .filter-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .filter-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    min-width: 60px;
  }
  .filter-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .filter-tag {
    padding: 0.375rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-body);
    background: var(--color-bg-subtle);
    border-radius: 999px;
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .filter-tag:hover {
    background: var(--color-accent);
    color: var(--color-text-white);
  }
</style>

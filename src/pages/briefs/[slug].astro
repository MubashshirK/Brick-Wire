---
import PageLayout from '../../layouts/PageLayout.astro';
import { client, BRIEFS_QUERY, BRIEF_QUERY, urlFor, toHTMLBody } from '../../lib/sanity';
import type { Brief } from '../../lib/sanity';
export async function getStaticPaths() {
  const briefs: Brief[] = await client.fetch(BRIEFS_QUERY);
  return briefs.map(b => ({ params: { slug: b.slug.current } }));
}
const { slug } = Astro.params;
const brief: Brief = await client.fetch(BRIEF_QUERY, { slug });
const category = brief.sector?.name || brief.market?.name || '';
const bodyHTML = toHTMLBody(brief.body);
---

<PageLayout title={brief.title}>
  <article class="article-page section-padding">
    <div class="container" style="max-width: var(--container-narrow);">
      <div class="article-meta">
        <span class="article-category">{category}</span>
        <time>{new Date(brief.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
      </div>
      <h1 class="article-title">{brief.title}</h1>
      <div class="article-share">
        <span>Share:</span>
        <a href="#" aria-label="Copy link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 10a2 2 0 1 1 0-4 2 2 0 0 1 0 4zM12 6a2 2 0 1 1 0-4 2 2 0 0 1 0 4zM12 14a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/><path d="M6.5 9.5l3 1M9.5 5.5l-3 1"/></svg>
        </a>
      </div>
      {brief.image && (
        <div class="article-hero-image">
          <img src={urlFor(brief.image).width(800).url()} alt={brief.title} style="width:100%;border-radius:1rem;margin-bottom:2rem;" />
        </div>
      )}
      {!brief.image && (
        <div class="article-hero-image">
          <div class="article-hero-placeholder"></div>
        </div>
      )}
      <div class="article-body" set:html={bodyHTML}></div>
    </div>
  </article>
</PageLayout>

<style>
  .article-page { padding-top: calc(var(--header-height) + 2rem); }
  .article-meta { display: flex; gap: 1rem; margin-bottom: 1rem; }
  .article-category { font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; color: var(--color-accent); }
  .article-meta time { font-size: 0.875rem; color: var(--color-text-muted); }
  .article-title { font-size: var(--fs-heading-1); line-height: 1.15; margin-bottom: 1.5rem; }
  .article-share { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem; }
  .article-share span { font-size: 0.875rem; color: var(--color-text-muted); }
  .article-share a { color: var(--color-text-muted); transition: color var(--transition-fast); }
  .article-share a:hover { color: var(--color-accent); }
  .article-hero-placeholder {
    width: 100%;
    padding-bottom: 52%;
    background: var(--color-bg-subtle);
    border-radius: 1rem;
    margin-bottom: 2rem;
  }
  .article-body p {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: var(--color-text-body);
  }
</style>

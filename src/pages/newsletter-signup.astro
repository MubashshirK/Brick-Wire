---
import PageLayout from '../layouts/PageLayout.astro';
import { SITE } from '../lib/constants';
---

<PageLayout title="Subscribe">
  <section class="subscribe-page section-padding">
    <div class="container" style="max-width: 600px; text-align: center;">
      <h1 class="subscribe-title">Start your day with<br />real estate's top news.</h1>
      <p class="subscribe-desc">Get smarter about what matters. Join {SITE.subscriberCount} professionals who read Brick Wire daily.</p>

      {Astro.url.searchParams.get('success') === 'true' && (
        <div class="subscribe-success">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="24" r="22" fill="var(--color-accent)" opacity="0.1"/>
            <path d="M14 24l7 7l13-13" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <h2>You're subscribed!</h2>
          <p>Check your inbox for a welcome email.</p>
        </div>
      )}

      <form class="subscribe-form" action="/api/subscribe" method="POST">
        <input type="hidden" name="form_location" value="dedicated" />
        <input type="hidden" name="publication" value="Brick Wire" />

        <div class="subscribe-field">
          <label for="first-name">First Name</label>
          <input id="first-name" name="firstName" type="text" placeholder="Your first name" />
        </div>

        <div class="subscribe-field">
          <label for="email">Email*</label>
          <input id="email" name="email" type="email" placeholder="Your email address" required />
        </div>

        <div class="subscribe-field">
          <label for="company">Company</label>
          <input id="company" name="company" type="text" placeholder="Company name (i.e. Brick Wire)" />
        </div>

        <button type="submit" class="btn btn-primary subscribe-cta">Subscribe</button>
      </form>

      <p class="subscribe-privacy">Your privacy is our priority. Unsubscribe anytime.</p>

      <div class="subscribe-logos">
        <p>Join professionals from:</p>
        <div class="subscribe-logos-row">
          <span>CBRE</span><span>JLL</span><span>Colliers</span><span>Blackstone</span><span>CoStar</span>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .subscribe-page {
    padding-top: calc(var(--header-height) + 3rem);
    padding-bottom: 4rem;
  }
  .subscribe-title {
    font-family: var(--font-heading);
    font-size: var(--fs-heading-1);
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .subscribe-desc {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }
  .subscribe-success {
    padding: 2rem;
    background: var(--color-bg-light);
    border-radius: 1rem;
    margin-bottom: 2rem;
  }
  .subscribe-success h2 {
    font-family: var(--font-heading);
    margin: 1rem 0 0.5rem;
    color: var(--color-accent);
  }
  .subscribe-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-align: left;
  }
  .subscribe-field label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
    color: var(--color-text-primary);
  }
  .subscribe-field input {
    width: 100%;
    padding: 0.9375rem 1.25rem;
    border: 2px solid var(--color-border);
    font-size: 1rem;
    outline: none;
    transition: border-color var(--transition-fast);
  }
  .subscribe-field input:focus {
    border-color: var(--color-accent);
  }
  .subscribe-cta {
    width: 100%;
    padding: 1rem;
    font-size: 0.9375rem;
  }
  .subscribe-privacy {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-top: 1rem;
  }
  .subscribe-logos {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .subscribe-logos p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .subscribe-logos-row {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .subscribe-logos-row span {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-muted);
    opacity: 0.5;
  }
</style>

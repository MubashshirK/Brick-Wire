---
import PageLayout from '../layouts/PageLayout.astro';
import { client, PAGE_QUERY, toHTMLBody } from '../lib/sanity';
import type { Page } from '../lib/sanity';
export async function getStaticPaths() {
  const pagesData: Page[] = await client.fetch(`*[_type == "page"] { slug }`);
  return pagesData.map(p => ({ params: { slug: p.slug.current } }));
}
const { slug } = Astro.params;
let pageData: Page | null = null;
let bodyHTML = '';
let pageTitle = 'Page';
let pageDesc = '';
if (slug) {
  pageData = await client.fetch(PAGE_QUERY, { slug });
  if (pageData) {
    pageTitle = pageData.title;
    pageDesc = pageData.seoDescription || '';
    bodyHTML = toHTMLBody(pageData.body);
  }
}
---

<PageLayout title={pageTitle} description={pageDesc}>
  <section class="static-page section-padding">
    <div class="container" style="max-width: var(--container-narrow);">
      <h1 class="static-title">{pageTitle}</h1>
      {bodyHTML ? (
        <div class="static-body" set:html={bodyHTML}></div>
      ) : (
        <div class="static-body">
          <p>This page is coming soon. Content will be managed through the Brick Wire CMS.</p>
          <p>In the meantime, feel free to <a href="/contact-us/">contact us</a> with any questions.</p>
        </div>
      )}
    </div>
  </section>
</PageLayout>

<style>
  .static-page { padding-top: calc(var(--header-height) + 2rem); }
  .static-title { font-size: var(--fs-heading-1); margin-bottom: 1.5rem; }
  .static-body p { font-size: 1.125rem; line-height: 1.8; margin-bottom: 1.5rem; color: var(--color-text-body); }
  .static-body a { color: var(--color-accent); }
</style>

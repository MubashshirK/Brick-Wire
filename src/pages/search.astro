---
import PageLayout from '../layouts/PageLayout.astro';
import { SITE } from '../lib/constants';

const query = Astro.url.searchParams.get('q') || '';
---

<PageLayout title={`Search${query ? ` — "${query}"` : ''} — ${SITE.name}`}>
  <section class="search-page section-padding">
    <div class="container">
      <div class="search-header">
        <h1 class="search-heading">Search</h1>
        <div class="search-bar">
          <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="9" r="7"/>
            <path d="M14 14l4 4"/>
          </svg>
          <input
            type="search"
            id="searchInput"
            class="search-input"
            value={query}
            placeholder="Search briefs, newsletters, reviews..."
            autocomplete="off"
            autofocus={!query}
          />
        </div>
      </div>

      <div id="searchResults">
        <div class="search-empty-state">
          <div class="search-empty-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"/>
              <path d="M21 21l-4.35-4.35"/>
            </svg>
          </div>
          <h2>Start searching</h2>
          <p>Enter a keyword to search across briefs, reviews, newsletters, and podcast episodes.</p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script define:vars={{ query }}>
  let debounceTimer;

  function debounce(fn, delay) {
    return (...args) => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => fn(...args), delay);
    };
  }

  async function performSearch(q) {
    const resultsContainer = document.getElementById('searchResults');
    if (!resultsContainer) return;

    if (!q || q.length < 2) {
      resultsContainer.innerHTML = `
        <div class="search-empty-state">
          <div class="search-empty-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"/>
              <path d="M21 21l-4.35-4.35"/>
            </svg>
          </div>
          <h2>Start searching</h2>
          <p>Enter a keyword to search across briefs, reviews, newsletters, and podcast episodes.</p>
        </div>
      `;
      return;
    }

    resultsContainer.innerHTML = `
      <div class="search-loading">
        <div class="loading-spinner"></div>
        <span>Searching for "${q}"...</span>
      </div>
    `;

    try {
      const res = await fetch(`/api/search?q=${encodeURIComponent(q)}`);
      const data = await res.json();

      if (data.error || !data.results) {
        resultsContainer.innerHTML = `
          <div class="search-empty-state">
            <div class="search-empty-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v4M12 16h.01"/>
              </svg>
            </div>
            <h2>Something went wrong</h2>
            <p>Please try again or <a href="/contact-us/">contact us</a> if the problem persists.</p>
          </div>
        `;
        return;
      }

      const { briefs, reviews, newsletters, episodes } = data.results;
      const total = data.total;

      if (total === 0) {
        resultsContainer.innerHTML = `
          <div class="search-empty-state">
            <div class="search-empty-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21l-4.35-4.35"/>
              </svg>
            </div>
            <h2>No results for "${data.query}"</h2>
            <p>Try a different keyword or browse content by <a href="/briefs/">briefs</a>, <a href="/reviews/">reviews</a>, or <a href="/newsletters/">newsletters</a>.</p>
          </div>
        `;
        return;
      }

      let html = `<div class="search-meta"><span class="search-count">${total} result${total !== 1 ? 's' : ''} for "<em>${data.query}</em>"</span></div>`;

      if (briefs && briefs.length > 0) {
        html += `
          <div class="search-section">
            <h2 class="search-section-title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
              </svg>
              Briefs
            </h2>
            <div class="search-list">
              ${briefs.map(b => `
                <a href="/briefs/${b.slug.current}/" class="search-item">
                  <div class="search-item-body">
                    <span class="search-item-category">${b.sector?.name || b.market?.name || 'Brief'}</span>
                    <h3 class="search-item-title">${b.title}</h3>
                    ${b.excerpt ? `<p class="search-item-excerpt">${b.excerpt.substring(0, 120)}${b.excerpt.length > 120 ? '...' : ''}</p>` : ''}
                    <span class="search-item-date">${new Date(b.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                  </div>
                </a>
              `).join('')}
            </div>
            <a href="/briefs/" class="search-view-all">View All Briefs</a>
          </div>
        `;
      }

      if (reviews && reviews.length > 0) {
        html += `
          <div class="search-section">
            <h2 class="search-section-title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              Reviews
            </h2>
            <div class="search-list">
              ${reviews.map(r => `
                <a href="/reviews/${r.slug.current}/" class="search-item">
                  <div class="search-item-body">
                    <span class="search-item-category">Review</span>
                    <h3 class="search-item-title">${r.title}</h3>
                    <div class="search-item-meta">
                      <span class="search-item-stars">${'★'.repeat(r.rating)}${'☆'.repeat(5 - r.rating)}</span>
                      <span class="search-item-date">${new Date(r.date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span>
                    </div>
                  </div>
                </a>
              `).join('')}
            </div>
            <a href="/reviews/" class="search-view-all">View All Reviews</a>
          </div>
        `;
      }

      if (newsletters && newsletters.length > 0) {
        html += `
          <div class="search-section">
            <h2 class="search-section-title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              Newsletters
            </h2>
            <div class="search-list">
              ${newsletters.map(n => `
                <a href="/newsletters/${n.edition}/issue/${n.slug.current}/" class="search-item">
                  <div class="search-item-body">
                    <span class="search-item-category">${n.edition.charAt(0).toUpperCase() + n.edition.slice(1)} Edition</span>
                    <h3 class="search-item-title">${n.title}</h3>
                    <span class="search-item-date">${new Date(n.issueDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                  </div>
                </a>
              `).join('')}
            </div>
            <a href="/newsletters/" class="search-view-all">View All Newsletters</a>
          </div>
        `;
      }

      if (episodes && episodes.length > 0) {
        html += `
          <div class="search-section">
            <h2 class="search-section-title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                <line x1="12" y1="19" x2="12" y2="23"/>
                <line x1="8" y1="23" x2="16" y2="23"/>
              </svg>
              Podcast Episodes
            </h2>
            <div class="search-list">
              ${episodes.map(e => `
                <a href="/podcast/${e.slug.current}/" class="search-item">
                  <div class="search-item-body">
                    <span class="search-item-category">${e.guest ? `Guest: ${e.guest}` : 'Podcast'}</span>
                    <h3 class="search-item-title">${e.title}</h3>
                    <span class="search-item-date">${new Date(e.episodeDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                  </div>
                </a>
              `).join('')}
            </div>
            <a href="/podcast/" class="search-view-all">View All Episodes</a>
          </div>
        `;
      }

      resultsContainer.innerHTML = html;
    } catch {
      resultsContainer.innerHTML = `
        <div class="search-empty-state">
          <div class="search-empty-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 8v4M12 16h.01"/>
            </svg>
          </div>
          <h2>Connection error</h2>
          <p>Unable to complete the search. Please try refreshing the page.</p>
        </div>
      `;
    }
  }

  const searchInput = document.getElementById('searchInput');

  searchInput.addEventListener('input', debounce(() => {
    const q = searchInput.value.trim();
    const url = new URL(window.location.href);
    if (q) {
      url.searchParams.set('q', q);
    } else {
      url.searchParams.delete('q');
    }
    window.history.replaceState({}, '', url.toString());
    performSearch(q);
  }, 300));

  performSearch(query);
</script>

<style>
  .search-page {
    padding-top: calc(var(--header-height) + 2rem);
    min-height: calc(100vh - var(--header-height));
  }

  .search-header {
    margin-bottom: 2.5rem;
  }

  .search-heading {
    font-family: var(--font-heading);
    font-size: var(--fs-heading-1);
    margin-bottom: 1.25rem;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.9375rem 1.25rem;
    background: var(--color-bg-white);
    border: 2px solid var(--color-border);
    border-radius: 0.75rem;
    transition: border-color var(--transition-fast);
    box-shadow: var(--shadow-sm);
  }

  .search-bar:focus-within {
    border-color: var(--color-accent);
  }

  .search-icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 1rem;
    background: transparent;
    color: var(--color-text-primary);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-input::-webkit-search-cancel-button {
    cursor: pointer;
  }
</style>

<style is:global>
  .search-loading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    padding: 1.5rem 0;
  }

  .loading-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-accent);
    border-radius: 50%;
    animation: search-spin 0.7s linear infinite;
    flex-shrink: 0;
  }

  @keyframes search-spin {
    to { transform: rotate(360deg); }
  }

  .search-meta {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .search-count {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .search-count em {
    font-style: normal;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .search-section {
    margin-bottom: 2.5rem;
  }

  .search-section:last-child {
    margin-bottom: 0;
  }

  .search-view-all {
    display: inline;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 800;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 2px;
    transition: color 0.15s ease;
    margin-top: 1rem;
  }

  .search-view-all:hover {
    color: var(--color-accent);
  }

  .search-section-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
    padding-bottom: 0.625rem;
    border-bottom: 2px solid var(--color-accent);
  }

  .search-section-title svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .search-list {
    display: flex;
    flex-direction: column;
  }

  .search-item {
    display: block;
    padding: 1.125rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s ease;
  }

  .search-item:hover {
    opacity: 0.8;
  }

  .search-item:last-child {
    border-bottom: none;
  }

  .search-item-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .search-item-category {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-accent);
  }

  .search-item-title {
    font-family: 'Inter', sans-serif;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-text-primary);
    margin: 0;
    transition: color 0.15s ease;
  }

  .search-item:hover .search-item-title {
    color: var(--color-accent);
  }

  .search-item-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0.125rem 0 0;
  }

  .search-item-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.125rem;
  }

  .search-item-stars {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-accent);
  }

  .search-item-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .search-empty-state {
    text-align: center;
    padding: 3rem 2rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .search-empty-icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1.25rem;
    color: var(--color-text-muted);
  }

  .search-empty-state h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    color: var(--color-text-primary);
    margin-bottom: 0.625rem;
  }

  .search-empty-state p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .search-empty-state a {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .search-empty-state a:hover {
    text-decoration: underline;
  }

  @media (max-width: 48em) {
    .search-bar {
      padding: 0.875rem 1rem;
    }

    .search-section-title {
      font-size: 1rem;
    }
  }
</style>